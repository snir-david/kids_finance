rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if the authenticated user is listed as a parent in the family doc.
    // Using parentIds array in Firestore (not JWT claims) so family membership
    // can never be spoofed by manipulating the user's own userProfile document.
    function isParentOfFamily(familyId) {
      return isAuthenticated() &&
             request.auth.uid in
               get(/databases/$(database)/documents/families/$(familyId)).data.parentIds;
    }

    // Validates a bucket document on creation.
    // Enforces required fields and non-negative balance.
    function validBucketCreate() {
      let d = request.resource.data;
      return d.keys().hasAll(['balance', 'childId', 'familyId', 'type', 'lastUpdatedAt'])
          && d.balance >= 0
          && d.childId is string && d.childId.size() > 0
          && d.familyId is string && d.familyId.size() > 0
          && d.type is string && d.type.size() > 0;
    }

    // Bucket updates must never produce a negative balance.
    function validBucketUpdate() {
      return request.resource.data.balance >= 0;
    }

    // Check if the authenticated user's JWT claims identify them as a specific
    // child within the family. Currently children do not hold Firebase Auth
    // accounts, so this always evaluates to false in production. It is defined
    // here to satisfy the goals rule structure and for future extension.
    function isChildOfFamily(familyId, childId) {
      return isAuthenticated() &&
             request.auth.token.get('familyId', '') == familyId &&
             request.auth.token.get('childId', '') == childId;
    }

    // Validates a child document on creation.
    function validChildCreate() {
      let d = request.resource.data;
      return d.keys().hasAll(['displayName', 'avatarEmoji', 'familyId', 'createdAt'])
          && d.displayName is string && d.displayName.size() > 0 && d.displayName.size() <= 50
          && d.familyId is string && d.familyId.size() > 0;
    }

    // ── User Profiles ─────────────────────────────────────────────────────────
    // Each parent user can read/write only their own profile.

    match /userProfiles/{uid} {
      allow read, write: if isAuthenticated() && request.auth.uid == uid;
    }

    // ── Families ──────────────────────────────────────────────────────────────

    match /families/{familyId} {
      // Any parent in this family can read the family doc.
      allow read: if isParentOfFamily(familyId);
      // Any parent can update the family (e.g. add children, add co-parent).
      allow write: if isParentOfFamily(familyId);
      // Allow the initial creation by any authenticated user (first-time setup).
      allow create: if isAuthenticated() &&
                       request.auth.uid in request.resource.data.parentIds;

      // ── Children ────────────────────────────────────────────────────────────
      // Only parents can read or write child documents.
      // Hard-delete is prohibited — use archived: true (soft-delete).

      match /children/{childId} {
        allow read: if isParentOfFamily(familyId);
        allow create: if isParentOfFamily(familyId) && validChildCreate();
        allow update: if isParentOfFamily(familyId);
        allow delete: if false;
      }

      // ── Buckets ─────────────────────────────────────────────────────────────
      // Only parents can read or modify bucket documents.
      // Balances are validated to be non-negative on every write.
      // Hard-delete is prohibited.

      match /children/{childId}/buckets/{bucketType} {
        allow read: if isParentOfFamily(familyId);
        allow create: if isParentOfFamily(familyId) && validBucketCreate();
        allow update: if isParentOfFamily(familyId) && validBucketUpdate();
        allow delete: if false;
      }

      // ── Transactions (append-only log) ───────────────────────────────────────

      match /transactions/{txnId} {
        allow read:   if isParentOfFamily(familyId);
        // Parents can create transactions; no edits/deletes allowed.
        allow create: if isParentOfFamily(familyId);
        allow update, delete: if false;
      }

      // ── Multiplier events (append-only log) ──────────────────────────────────
      // Multiplier must be > 0 — rules enforce this even for direct API calls.

      match /multiplierEvents/{eventId} {
        allow read:   if isParentOfFamily(familyId);
        allow create: if isParentOfFamily(familyId) &&
                         request.resource.data.multiplier > 0;
        allow update, delete: if false;
      }

      match /charityResets/{resetId} {
        allow read:   if isParentOfFamily(familyId);
        allow create: if isParentOfFamily(familyId);
        allow update, delete: if false;
      }

      // ── Savings Goals ────────────────────────────────────────────────────────
      // Parents manage goals; children can read their own goals.

      match /children/{childId}/goals/{goalId} {
        allow read: if isParentOfFamily(familyId) || isChildOfFamily(familyId, childId);
        allow create, update, delete: if isParentOfFamily(familyId);
      }

      // ── Achievement Badges ───────────────────────────────────────────────────
      // Badges are awarded by the parent/app. Children can mark them as seen.

      match /children/{childId}/badges/{badgeId} {
        allow read: if isParentOfFamily(familyId) || isChildOfFamily(familyId, childId);
        allow create: if isParentOfFamily(familyId);
        allow update: if isParentOfFamily(familyId) || isChildOfFamily(familyId, childId);
      }
    }

    // ── Deny everything else ──────────────────────────────────────────────────

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
